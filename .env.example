# Copy this file to ".env" and fill in your real values.
# The .env file is gitignored, so your secrets stay on your machine.
# When deploying to Vercel, set these in Project Settings → Environment Variables.

ANTHROPIC_API_KEY=sk-ant-your-key-here

# Google Sheet lead capture — the Apps Script web app URL.
# Setup instructions: see scripts/google-sheet-webhook.gs
SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/your-deployment-id/exec
